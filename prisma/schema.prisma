// Schéma Prisma — ETCH Store
// Base de données : MySQL hébergée sur Railway

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADJOINT
  MEMBRE
  CLIENT
}

model User {
  id               String         @id @default(cuid())
  nom              String
  email            String         @unique
  telephone        String?
  motDePasse       String
  photo            String?        @db.Text
  role             Role           @default(MEMBRE)
  motDePasseChange Boolean        @default(false)
  creeLe           DateTime       @default(now())
  logs             LogConnexion[]
  messages         Message[]
}

model Produit {
  id          String         @id @default(cuid())
  titre       String
  description String         @db.Text
  prixUSD     Float
  etat        String
  categorie   String
  photos      String         @db.Text
  quantite    Int            @default(1)
  vedette     Boolean        @default(false)
  vues        Int            @default(0)
  disponible  Boolean        @default(true)
  creeLe      DateTime       @default(now())
  messages    Message[]
  attentes    ListeAttente[]
}

model Message {
  id          String   @id @default(cuid())
  clientId    String?
  client      User?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  nomClient   String
  emailClient String
  telephone   String?
  produitId   String?
  produit     Produit? @relation(fields: [produitId], references: [id], onDelete: SetNull)
  contenu     String   @db.Text
  lu          Boolean  @default(false)
  reponse     String?  @db.Text
  reponseLue  Boolean  @default(false)
  creeLe      DateTime @default(now())
}

model LogConnexion {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type       String   // "SUCCES" | "ECHEC" | "BLOQUE"
  ip         String
  userAgent  String   @db.Text
  emailTente String?
  creeLe     DateTime @default(now())
}

model ListeAttente {
  id          String   @id @default(cuid())
  emailClient String
  produitId   String
  produit     Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  creeLe      DateTime @default(now())

  @@unique([emailClient, produitId])
}

model Parametre {
  id     String @id @default(cuid())
  cle    String @unique
  valeur String @db.Text
}

model TentativeConnexion {
  id          String    @id @default(cuid())
  ip          String    @unique
  tentatives  Int       @default(0)
  bloqueJusqu DateTime?
  creeLe      DateTime  @default(now())
  misAJour    DateTime  @updatedAt
}
